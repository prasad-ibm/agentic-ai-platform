# ── Agentic AI Value Platform — Environment Variables ──────────────────────
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# On Railway, set DATABASE_URL automatically by adding a PostgreSQL service
# to your project. Railway injects it as an environment variable.
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/agenticai
# Railway:       Automatically set when you add a PostgreSQL plugin
DATABASE_URL=postgresql://postgres:password@localhost:5432/agenticai

# Server port (Railway sets this automatically — do not change for production)
PORT=3030

# Set to 'production' on Railway (enables SSL for PostgreSQL)
NODE_ENV=development
